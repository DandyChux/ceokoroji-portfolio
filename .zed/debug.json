// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
	{
		"adapter": "CodeLLDB",
		"label": "Debug Rust API",
		"request": "launch",
		"build": {
			"command": "cargo",
			"args": ["watch", "-q", "-c", "-w", "src/", "-x", "run"],
			"cwd": "${ZED_WORKTREE_ROOT}",
		},
		"program": "${ZED_WORKTREE_ROOT}/target/debug/ceokoroji-api",
		"cwd": "${ZED_WORKTREE_ROOT}",
		"stopOnEntry": false,
		"env": {
			"RUST_LOG": "debug,actix_web=debug,actix_server=info,sqlx=debug,actix_session=info",
			"RUST_BACKTRACE": "1",
		},
	},
]
